Cell[CellGroupData[{

Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{
   "alcune", " ", "considerazioni", " ", "per", " ", "rendere", " ", 
    "pi\[UGrave]", " ", "efficiente", " ", "la", " ", "ricerca", " ", 
    "soprattutto", " ", "quando", " ", "si", " ", "fa", " ", "con", " ", 
    "carta", " ", "e", " ", "penna"}], " ", "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
    RowBox[{"Partition", "[", 
     RowBox[{
      RowBox[{"blocks", "[", 
       RowBox[{"[", "1", "]"}], "]"}], ",", "5"}], "]"}], "//", "TableForm"}],
    "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{"(*", " ", 
   RowBox[{
   "stabilisco", " ", "le", " ", "lettere", " ", "pi\[UGrave]", " ", 
    "frequenti", " ", "nei", " ", "primi", " ", "30", " ", "caratteri", " ", 
    "del", " ", "testo"}], "*)"}], "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{"blk", " ", "=", 
    RowBox[{"blocks", "[", 
     RowBox[{"[", "2", "]"}], "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"t0", "=", "30"}], "\[IndentingNewLine]", 
   RowBox[{"troncato0", "=", 
    RowBox[{"Take", "[", 
     RowBox[{"blk", ",", "t0"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"st0", "=", 
    RowBox[{"SortBy", "[", 
     RowBox[{
      RowBox[{"Tally", "[", "troncato0", "]"}], ",", "Last"}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"ct0", "=", 
    RowBox[{"Map", "[", 
     RowBox[{"First", ",", 
      RowBox[{"Take", "[", 
       RowBox[{"st0", ",", 
        RowBox[{"-", "7"}]}], "]"}]}], "]"}]}], "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<7 lettere piu' frequenti nei primi \>\"", ",", "t0", 
     ",", "\"\< caratteri di testo : \>\"", ",", 
     RowBox[{"FromCode", "[", "ct0", "]"}]}], "]"}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "conto", " ", "il", " ", "numero", " ", "di", " ", "occorrenze", " ", 
     "di", " ", "quelle", " ", "lettere", " ", "nel", " ", "testo", " ", 
     "pi\[UGrave]", " ", "lungo", " ", 
     RowBox[{"(", 
      RowBox[{"almeno", " ", "100", " ", "caratteri"}], ")"}]}], "*)"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"t", "=", "100"}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"troncato", "=", 
     RowBox[{"Take", "[", 
      RowBox[{"blk", ",", "t"}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"SortBy", "[", 
     RowBox[{
      RowBox[{"Tally", "[", "troncato", "]"}], ",", "Last"}], "]"}], ";"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"con", " ", "questa", " ", "statistica", " ", "confronto", " ", 
     RowBox[{"l", "'"}], "indice", " ", "di", " ", "coincidenza", " ", 
     "troncato", " ", "alle", " ", "lettere", " ", "pi\[UGrave]", " ", 
     "frequenti"}], " ", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"conta0", "=", 
     RowBox[{"Map", "[", 
      RowBox[{
       RowBox[{
        RowBox[{"Count", "[", 
         RowBox[{"troncato", ",", "#"}], "]"}], "&"}], ",", "ct0"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<occorrenze delle prime 7 lettere considerati i primi \>\"", ",",
      "t0", ",", "\"\< caratteri, contate nei primi \>\"", ",", "t", 
     ",", "\"\< caratteri\\n\>\"", ",", "conta0"}], "]"}], 
   "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"Print", "[", 
    RowBox[{"\"\<indice di coincidenza troncato ai 7 piu frequenti : \>\"", ",",
      "\[IndentingNewLine]", 
     RowBox[{"N", "@", 
      RowBox[{"Apply", "[", 
       RowBox[{"Plus", ",", 
        RowBox[{
         RowBox[{"(", 
          RowBox[{"conta0", "/", "t"}], ")"}], "^", "2"}]}], "]"}]}], 
     ",", "\"\< (cf. con IcITA7 = \>\"", ",", "\[IndentingNewLine]", "IcITA7",
      ",", "\"\< e IcRND7 = \>\"", ",", "\[IndentingNewLine]", "IcRND7", 
     ",", "\"\<)\\n\>\""}], "]"}]}]}]], "Input",
