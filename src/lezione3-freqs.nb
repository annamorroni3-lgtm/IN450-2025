  RowBox[{"(*", " ", 
   RowBox[{"KASISKI", " ", "TEST"}], " ", "*)"}], "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{"(*", 
   RowBox[{
   "trovo", " ", "blocchi", " ", "ripetuti", " ", "nel", " ", "testo"}], " ", 
   "*)"}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
  "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"Distances", "[", 
     RowBox[{"parted_", ",", "rep_"}], "]"}], ":=", 
    RowBox[{"Flatten", "@", 
     RowBox[{"Position", "[", 
      RowBox[{"parted", ",", "rep"}], "]"}]}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"KasiskiTest", "[", 
     RowBox[{"text_", ",", "len_"}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"nparted", ",", "nreps", ",", "ndd"}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"parted", "=", 
        RowBox[{"Partition", "[", 
         RowBox[{"text", ",", "len", ",", "1"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"reps", "=", 
        RowBox[{"SortBy", "[", 
         RowBox[{
          RowBox[{"Select", "[", 
           RowBox[{
            RowBox[{"Tally", "[", "parted", "]"}], ",", 
            RowBox[{
             RowBox[{
              RowBox[{"#", "[", 
               RowBox[{"[", "2", "]"}], "]"}], "==", "2"}], "&"}]}], "]"}], ",",
           "Last"}], "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"dd", "=", 
        RowBox[{"Sort", "@", 
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Distances", "[", 
             RowBox[{"parted", ",", 
              RowBox[{"#", "[", 
               RowBox[{"[", "1", "]"}], "]"}]}], "]"}], "&"}], ",", "reps"}], 
          "]"}]}]}], ";", "\n", "     ", 
       RowBox[{"distanze", "=", 
        RowBox[{"Flatten", "@", 
         RowBox[{"Map", "[", 
          RowBox[{
           RowBox[{
            RowBox[{
             RowBox[{"Drop", "[", 
              RowBox[{"#", ",", "1"}], "]"}], "-", 
             RowBox[{"Drop", "[", 
              RowBox[{"#", ",", 
               RowBox[{"-", "1"}]}], "]"}]}], "&"}], ",", "dd"}], "]"}]}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"Apply", "[", 
        RowBox[{"GCD", ",", "distanze"}], "]"}]}]}], "\[IndentingNewLine]", 
     "]"}]}], "\[IndentingNewLine]", "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{"ipotesi", " ", "di", " ", "lunghezza", " ", "chiave"}], " ", 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{"mguess", "=", 
    RowBox[{"KasiskiTest", "[", 
     RowBox[{"ciphertext", ",", "6"}], "]"}]}], "\[IndentingNewLine]", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", " ", 
    RowBox[{
    "controllo", " ", "i", " ", "fattori", " ", "per", " ", "capire", " ", 
     "se", " ", "il", " ", "guess", " ", "\[EGrave]", " ", "verosimile"}], 
    " ", "*)"}], "\n", 
