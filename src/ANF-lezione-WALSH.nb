Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"GPT", " ", "Iterative", " ", "version"}], " ", "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{"WalshFWHT", "=", 
     RowBox[{"Compile", "[", 
      RowBox[{
       RowBox[{"{", 
        RowBox[{"{", 
         RowBox[{"x", ",", "_Real", ",", "1"}], "}"}], "}"}], ",", 
       RowBox[{"Module", "[", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{
           RowBox[{"y", "=", "x"}], ",", "n", ",", 
           RowBox[{"h", "=", "1"}], ",", "i", ",", "j", ",", "a", ",", "b"}], 
          "}"}], ",", 
         RowBox[{
          RowBox[{"n", "=", 
           RowBox[{"Length", "[", "y", "]"}]}], ";", "\[IndentingNewLine]", 
          RowBox[{"While", "[", 
           RowBox[{
            RowBox[{"h", "<", "n"}], ",", 
            RowBox[{
             RowBox[{"i", "=", "1"}], ";", "\[IndentingNewLine]", 
             RowBox[{"While", "[", 
              RowBox[{
               RowBox[{"i", "<=", "n"}], ",", 
               RowBox[{
                RowBox[{"j", "=", "i"}], ";", "\[IndentingNewLine]", 
                RowBox[{"While", "[", 
                 RowBox[{
                  RowBox[{"j", "<", 
                   RowBox[{"i", "+", "h"}]}], ",", 
                  RowBox[{
                   RowBox[{"a", "=", 
                    RowBox[{"y", "[", 
                    RowBox[{"[", "j", "]"}], "]"}]}], ";", 
                   "\[IndentingNewLine]", 
                   RowBox[{"b", "=", 
                    RowBox[{"y", "[", 
                    RowBox[{"[", 
                    RowBox[{"j", "+", "h"}], "]"}], "]"}]}], ";", 
                   "\[IndentingNewLine]", 
                   RowBox[{
                    RowBox[{"y", "[", 
                    RowBox[{"[", "j", "]"}], "]"}], "=", 
                    RowBox[{"a", "+", "b"}]}], ";", "\[IndentingNewLine]", 
                   RowBox[{
                    RowBox[{"y", "[", 
                    RowBox[{"[", 
                    RowBox[{"j", "+", "h"}], "]"}], "]"}], "=", 
                    RowBox[{"a", "-", "b"}]}], ";", "\[IndentingNewLine]", 
                   RowBox[{"j", "++"}], ";"}]}], "]"}], ";", 
                "\[IndentingNewLine]", 
                RowBox[{"i", "+=", 
                 RowBox[{"2", " ", "h"}]}], ";"}]}], "]"}], ";", 
             "\[IndentingNewLine]", 
             RowBox[{"h", "*=", "2"}], ";"}]}], "]"}], ";", 
          "\[IndentingNewLine]", "y"}]}], "]"}], ",", 
       RowBox[{"CompilationTarget", "->", "\"\<C\>\""}], ",", 
       RowBox[{"RuntimeOptions", "->", "\"\<Speed\>\""}]}], "]"}]}], ";"}], 
   "\n", "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{"wrapper", " ", "con", " ", "normalizzazione", " ", "opzionale"}],
     "*)"}], "\n", 
   RowBox[{
    RowBox[{
     RowBox[{"WalshFWHTNorm", "[", 
      RowBox[{"f_List", ",", 
       RowBox[{"norm_", ":", "None"}]}], "]"}], "/;", 
     RowBox[{"IntegerQ", "[", 
      RowBox[{"Log2", "[", 
       RowBox[{"Length", "[", "f", "]"}], "]"}], "]"}]}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"y", "=", 
         RowBox[{"N", "[", 
          RowBox[{"Developer`ToPackedArray", "[", "f", "]"}], "]"}]}], ",", 
        "\[IndentingNewLine]", 
        RowBox[{"n", "=", 
         RowBox[{"Length", "[", "f", "]"}]}]}], "\[IndentingNewLine]", "}"}], 
      ",", "\[IndentingNewLine]", 
      RowBox[{
       RowBox[{"y", "=", 
        RowBox[{"WalshFWHT", "[", "y", "]"}]}], ";", "\[IndentingNewLine]", 
       RowBox[{"Switch", "[", 
        RowBox[{"norm", ",", "\[IndentingNewLine]", "\"\<Unitary\>\"", ",", 
         RowBox[{"y", "/", 
          RowBox[{"Sqrt", "[", "n", "]"}]}], ",", 
         "\[IndentingNewLine]", "\"\<Inverse\>\"", ",", 
         RowBox[{"y", "/", "n"}], ",", "\[IndentingNewLine]", "_", ",", 
         "\[IndentingNewLine]", "y"}], "]"}]}]}], "\[IndentingNewLine]", 
     "]"}]}], "\n"}]}]], "Input",
