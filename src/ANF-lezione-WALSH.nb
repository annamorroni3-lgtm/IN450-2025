Cell[BoxData[
 RowBox[{
  RowBox[{"(*", " ", 
   RowBox[{"GPT", " ", "Modified", " ", "Version"}], "*)"}], 
  "\[IndentingNewLine]", "\[IndentingNewLine]", "\[IndentingNewLine]", 
  RowBox[{
   RowBox[{
    RowBox[{
     RowBox[{"Walsh", "[", 
      RowBox[{"f_List", ",", 
       RowBox[{"norm_", ":", "None"}]}], "]"}], "/;", 
     RowBox[{"IntegerQ", "[", 
      RowBox[{"Log2", "[", 
       RowBox[{"Length", "[", "f", "]"}], "]"}], "]"}]}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"n", "=", 
        RowBox[{"Length", "[", "f", "]"}]}], "}"}], ",", 
      "\[IndentingNewLine]", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"n", "==", "1"}], ",", "\[IndentingNewLine]", "f", ",", 
        "\[IndentingNewLine]", 
        RowBox[{"With", "[", "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"m", "=", 
             RowBox[{"n", "/", "2"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"f0", "=", 
             RowBox[{"Take", "[", 
              RowBox[{"f", ",", 
               RowBox[{"n", "/", "2"}]}], "]"}]}], ",", "\[IndentingNewLine]", 
            RowBox[{"f1", "=", 
             RowBox[{"Drop", "[", 
              RowBox[{"f", ",", 
               RowBox[{"n", "/", "2"}]}], "]"}]}]}], "\[IndentingNewLine]", 
           "}"}], ",", "\[IndentingNewLine]", 
          RowBox[{"With", "[", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", "\[IndentingNewLine]", 
             RowBox[{"y", "=", 
              RowBox[{"Join", "[", 
               RowBox[{
                RowBox[{"Walsh", "[", 
                 RowBox[{
                  RowBox[{"f0", "+", "f1"}], ",", "None"}], "]"}], ",", 
                RowBox[{"Walsh", "[", 
                 RowBox[{
                  RowBox[{"f0", "-", "f1"}], ",", "None"}], "]"}]}], "]"}]}], 
             "\[IndentingNewLine]", "}"}], ",", "\[IndentingNewLine]", 
            RowBox[{"Switch", "[", 
             RowBox[{"norm", ",", "\[IndentingNewLine]", "\"\<Unitary\>\"", ",", 
              RowBox[{"y", "/", 
               RowBox[{"Sqrt", "[", "n", "]"}]}], ",", 
              "\[IndentingNewLine]", "\"\<Inverse\>\"", ",", 
              RowBox[{"y", "/", "n"}], ",", "\[IndentingNewLine]", "_", ",", 
              "\[IndentingNewLine]", "y"}], "]"}]}], "\[IndentingNewLine]", 
           "]"}]}], "\[IndentingNewLine]", "]"}]}], "\[IndentingNewLine]", 
       "]"}]}], "\[IndentingNewLine]", "]"}]}], "\n"}]}]], "Input",
