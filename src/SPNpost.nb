       RowBox[{"alpha", "=", 
        RowBox[{"nodes", "[", 
         RowBox[{"[", 
          RowBox[{"node", ",", "2"}], "]"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"weights", "=", 
        RowBox[{"DigitCount", "[", 
         RowBox[{
          RowBox[{"Range", "[", 
           RowBox[{"0", ",", "15"}], "]"}], ",", "2", ",", "1"}], "]"}]}], ";",
        "\[IndentingNewLine]", 
       RowBox[{"row", "=", 
        RowBox[{"bias", "[", 
         RowBox[{"[", 
          RowBox[{"alpha", "+", "1"}], "]"}], "]"}]}], ";", 
