       RowBox[{"NL", "[", 
        RowBox[{"alpha", ",", "beta"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"alpha", ",", "0", ",", 
         RowBox[{
          RowBox[{"2", "^", "l"}], "-", "1"}]}], "}"}], ",", 
       RowBox[{"{", 
        RowBox[{"beta", ",", "0", ",", 
         RowBox[{
          RowBox[{"2", "^", "l"}], "-", "1"}]}], "}"}]}], "]"}]}], ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"bias", "=", 
     RowBox[{"Abs", "[", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{"tab", "-", 
         RowBox[{"2", "^", 
          RowBox[{"(", 
           RowBox[{"l", "-", "1"}], ")"}]}]}], ")"}], "/", "16"}], "]"}]}], 
    ";"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"MakeBias", "[", "node_", "]"}], ":=", 
    RowBox[{"Module", "[", "\[IndentingNewLine]", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"alpha", ",", "weights"}], "}"}], ",", "\[IndentingNewLine]", 
