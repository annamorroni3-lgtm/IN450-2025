Cell[BoxData[
 RowBox[{
  RowBox[{"Walsh", "[", "f_", "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"n", ",", "f1", ",", "f0", ",", "ret"}], "}"}], ",", "\n", 
    RowBox[{"(", "\n", 
     RowBox[{
      RowBox[{"n", "=", 
       RowBox[{"Length", "[", "f", "]"}]}], ";", "\n", 
      RowBox[{"Print", "[", 
       RowBox[{"\"\<input \>\"", ",", "f"}], "]"}], ";", "\n", 
      RowBox[{"If", "[", 
       RowBox[{
        RowBox[{"n", "==", "1"}], ",", 
        RowBox[{
         RowBox[{"Print", "[", 
          RowBox[{"\"\<base : \>\"", ",", "f"}], "]"}], ";", "f"}], ",", "\n", 
        RowBox[{
         RowBox[{
          RowBox[{"{", 
           RowBox[{"f0", ",", "f1"}], "}"}], "=", 
          RowBox[{"Partition", "[", 
           RowBox[{"f", ",", 
            RowBox[{"n", "/", "2"}]}], "]"}]}], ";", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<f0 : \>\"", ",", "f0"}], "]"}], ";", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<f1 : \>\"", ",", "f1"}], "]"}], ";", "\n", 
         RowBox[{"ret", "=", 
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{
             RowBox[{"Print", "[", 
              RowBox[{"\"\<S \>\"", ",", 
               RowBox[{"f0", "+", "f1"}]}], "]"}], ";", 
             RowBox[{"Walsh", "[", 
              RowBox[{"f0", "+", "f1"}], "]"}]}], ",", 
            RowBox[{
             RowBox[{"Print", "[", 
              RowBox[{"\"\<D\>\"", ",", 
               RowBox[{"f0", "-", "f1"}]}], "]"}], ";", 
             RowBox[{"Walsh", "[", 
              RowBox[{"f0", "-", "f1"}], "]"}]}]}], "]"}]}], ";", "\n", 
         RowBox[{"Print", "[", 
          RowBox[{"\"\<walsh: \>\"", ",", "ret"}], "]"}], ";", "\n", 
         "ret"}]}], "\n", "]"}]}], ")"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.988458847075433*^9, 3.988458887692976*^9}, {
