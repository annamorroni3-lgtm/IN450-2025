Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"Walsh", "[", "f_", "]"}], ":=", 
   RowBox[{"Module", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"n", ",", "f1", ",", "f0", ",", "ret"}], "}"}], ",", 
     "\[IndentingNewLine]", 
     RowBox[{"(", "\n", "\t", 
      RowBox[{
       RowBox[{"n", "=", 
        RowBox[{"Length", "[", "f", "]"}]}], ";", "\n", "\t", 
       RowBox[{"If", "[", 
        RowBox[{
         RowBox[{"n", "==", "1"}], ",", "\[IndentingNewLine]", "\t", "f", ",",
          "\n", "\t\t", 
         RowBox[{
          RowBox[{
           RowBox[{"{", 
            RowBox[{"f0", ",", "f1"}], "}"}], "=", 
           RowBox[{"Partition", "[", 
            RowBox[{"f", ",", 
             RowBox[{"n", "/", "2"}]}], "]"}]}], ";", "\n", "\t\t", 
          RowBox[{"Join", "[", 
           RowBox[{
            RowBox[{"Walsh", "[", 
             RowBox[{"f0", "+", "f1"}], "]"}], ",", 
            RowBox[{"Walsh", "[", 
             RowBox[{"f0", "-", "f1"}], "]"}]}], "]"}]}]}], "\n", "\t", 
        "]"}]}], "\[IndentingNewLine]", ")"}]}], "\[IndentingNewLine]", 
    "]"}]}], "\n"}]], "Input",
