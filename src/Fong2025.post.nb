Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"FieldInverse", "[", "a_", "]"}], ":=", 
   RowBox[{"(", "\[IndentingNewLine]", 
    RowBox[{
     RowBox[{
      RowBox[{"{", 
       RowBox[{"u", ",", "v", ",", "g1", ",", "g2"}], "}"}], "=", 
      RowBox[{"{", 
       RowBox[{
        RowBox[{"Int2Poly", "[", "a", "]"}], ",", "f", ",", "1", ",", "0"}], 
       "}"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"Until", "[", 
      RowBox[{
       RowBox[{"u", "==", "1"}], ",", "\[IndentingNewLine]", 
       RowBox[{"(", "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"While", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"PolynomialMod", "[", 
             RowBox[{"u", ",", "x"}], "]"}], "==", "0"}], ",", 
           "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"u", "=", 
             RowBox[{"ExpandAll", "[", 
              RowBox[{"u", "/", "x"}], "]"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{"If", "[", 
             RowBox[{
              RowBox[{
               RowBox[{"PolynomialMod", "[", 
                RowBox[{"g1", ",", "x"}], "]"}], "==", "0"}], ",", 
              "\[IndentingNewLine]", 
              RowBox[{"g1", "=", 
               RowBox[{"ExpandAll", "[", 
                RowBox[{"g1", "/", "x"}], "]"}]}], ",", "\[IndentingNewLine]", 
              RowBox[{"g1", "=", 
               RowBox[{"PolynomialMod", "[", 
                RowBox[{
                 RowBox[{
                  RowBox[{"(", 
                   RowBox[{"g1", "+", "f"}], ")"}], "/", "x"}], ",", "2"}], 
                "]"}]}]}], "\[IndentingNewLine]", "]"}]}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{"u", "==", "1"}], ",", 
           RowBox[{"Return", "[", 
            RowBox[{"Poly2Int", "[", "g1", "]"}], "]"}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{"If", "[", 
          RowBox[{
           RowBox[{
            RowBox[{"Exponent", "[", 
             RowBox[{"u", ",", "x"}], "]"}], "<", 
            RowBox[{"Exponent", "[", 
             RowBox[{"v", ",", "x"}], "]"}]}], ",", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{
             RowBox[{"{", 
              RowBox[{"u", ",", "v"}], "}"}], "=", 
             RowBox[{"{", 
              RowBox[{"v", ",", "u"}], "}"}]}], ";", "\[IndentingNewLine]", 
            RowBox[{
             RowBox[{"{", 
              RowBox[{"g1", ",", "g2"}], "}"}], "=", 
             RowBox[{"{", 
              RowBox[{"g2", ",", "g1"}], "}"}]}]}]}], "]"}], ";", 
         "\[IndentingNewLine]", 
         RowBox[{
          RowBox[{"{", 
           RowBox[{"u", ",", "g1"}], "}"}], "=", 
          RowBox[{"PolynomialMod", "[", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{
              RowBox[{"u", "+", "v"}], ",", 
              RowBox[{"g1", "+", "g2"}]}], "}"}], ",", "2"}], "]"}]}], ";", 
         "\[IndentingNewLine]", "\[IndentingNewLine]", 
         RowBox[{"Print", "[", 
          RowBox[{"{", 
           RowBox[{"u", ",", "v", ",", "g1", ",", "g2"}], "}"}], "]"}]}], 
        "\[IndentingNewLine]", ")"}]}], "]"}]}], "\[IndentingNewLine]", 
    ")"}]}], "\[IndentingNewLine]"}]], "Input",
