Cell[BoxData[{
 RowBox[{
  RowBox[{
   RowBox[{"BitRotateRight", "[", 
    RowBox[{"a_", ",", "i_"}], "]"}], ":=", 
   RowBox[{"BitAnd", "[", 
    RowBox[{
     RowBox[{"BitXor", "[", 
      RowBox[{
       RowBox[{"BitShiftRight", "[", 
        RowBox[{"a", ",", 
         RowBox[{"8", "-", "i"}]}], "]"}], ",", 
       RowBox[{"BitShiftLeft", "[", 
        RowBox[{"a", ",", "i"}], "]"}]}], "]"}], ",", 
     RowBox[{
      RowBox[{"2", "^", "8"}], "-", "1"}]}], "]"}]}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"BitFieldInverse", "[", "a_", "]"}], ":=", 
  RowBox[{"(", "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{
     RowBox[{"{", 
      RowBox[{"u", ",", "v", ",", "g1", ",", "g2"}], "}"}], "=", 
     RowBox[{"{", 
      RowBox[{"a", ",", "bf", ",", "1", ",", "0"}], "}"}]}], ";", 
    "\[IndentingNewLine]", 
    RowBox[{"Until", "[", 
     RowBox[{
      RowBox[{"u", "==", "1"}], ",", "\[IndentingNewLine]", 
      RowBox[{"(", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"While", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Mod", "[", 
            RowBox[{"u", ",", "2"}], "]"}], "==", "0"}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{"u", "=", 
            RowBox[{"BitShiftRight", "[", "u", "]"}]}], ";", 
           "\[IndentingNewLine]", 
           RowBox[{"If", "[", 
            RowBox[{
             RowBox[{
              RowBox[{"Mod", "[", 
               RowBox[{"g1", ",", "2"}], "]"}], "==", "0"}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"g1", "=", 
              RowBox[{"BitShiftRight", "[", "g1", "]"}]}], ",", 
             "\[IndentingNewLine]", 
             RowBox[{"g1", "=", 
              RowBox[{"BitShiftRight", "[", 
               RowBox[{"BitXor", "[", 
                RowBox[{"g1", ",", "bf"}], "]"}], "]"}]}]}], 
            "\[IndentingNewLine]", "]"}]}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{"u", "==", "1"}], ",", 
          RowBox[{"Return", "[", "g1", "]"}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{"If", "[", 
         RowBox[{
          RowBox[{
           RowBox[{"Floor", "[", 
            RowBox[{"Log", "[", 
             RowBox[{"2", ",", "u"}], "]"}], "]"}], "<", 
           RowBox[{"Floor", "[", 
            RowBox[{"Log", "[", 
             RowBox[{"2", ",", "v"}], "]"}], "]"}]}], ",", 
          "\[IndentingNewLine]", 
          RowBox[{
           RowBox[{
            RowBox[{"{", 
             RowBox[{"u", ",", "v"}], "}"}], "=", 
            RowBox[{"{", 
             RowBox[{"v", ",", "u"}], "}"}]}], ";", "\[IndentingNewLine]", 
           RowBox[{
            RowBox[{"{", 
             RowBox[{"g1", ",", "g2"}], "}"}], "=", 
            RowBox[{"{", 
             RowBox[{"g2", ",", "g1"}], "}"}]}]}]}], "]"}], ";", 
        "\[IndentingNewLine]", 
        RowBox[{
         RowBox[{"{", 
          RowBox[{"u", ",", "g1"}], "}"}], "=", 
         RowBox[{"{", 
          RowBox[{
           RowBox[{"BitXor", "[", 
            RowBox[{"u", ",", "v"}], "]"}], ",", 
           RowBox[{"BitXor", "[", 
            RowBox[{"g1", ",", "g2"}], "]"}]}], "}"}]}], ";", 
        "\[IndentingNewLine]", "\[IndentingNewLine]", 
        RowBox[{"Print", "[", 
         RowBox[{"{", 
          RowBox[{"u", ",", "v", ",", "g1", ",", "g2"}], "}"}], "]"}]}], 
       "\[IndentingNewLine]", ")"}]}], "]"}]}], "\[IndentingNewLine]", 
   ")"}]}], "\[IndentingNewLine]"}], "Input",
