Cell[BoxData[{
 RowBox[{
  RowBox[{"BitRotateRight", "[", 
   RowBox[{"a_", ",", "i_"}], "]"}], ":=", 
  RowBox[{"BitAnd", "[", 
   RowBox[{
    RowBox[{"BitXor", "[", 
     RowBox[{
      RowBox[{"BitShiftRight", "[", 
       RowBox[{"a", ",", 
        RowBox[{"8", "-", "i"}]}], "]"}], ",", 
      RowBox[{"BitShiftLeft", "[", 
       RowBox[{"a", ",", "i"}], "]"}]}], "]"}], ",", 
    RowBox[{
     RowBox[{"2", "^", "8"}], "-", "1"}]}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SP", "[", 
   RowBox[{"x_", ",", "a_"}], "]"}], ":=", 
  RowBox[{"Mod", "[", 
   RowBox[{
    RowBox[{"DigitCount", "[", 
     RowBox[{
      RowBox[{"BitAnd", "[", 
       RowBox[{"x", ",", "a"}], "]"}], ",", "2", ",", "1"}], "]"}], ",", 
    "2"}], "]"}]}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{"SRD", "[", "a_", "]"}], ":=", 
  RowBox[{"FromDigits", "[", 
   RowBox[{
